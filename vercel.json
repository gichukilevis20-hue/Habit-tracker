{
  "buildCommand": "pip install -r requirements.txt",
  "devCommand": "python manage.py runserver 0.0.0.0:3000",
  "env": {
    "DEBUG": "False"
  },
  "functions": {
    "api/index.py": {
      "memory": 3008,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/static/(.*)",
      "status": 404
    },
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}
